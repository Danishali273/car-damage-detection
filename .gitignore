# Ignore everything by default
*

# Allow directories so git can traverse into them
!*/

# Allow Python files
!*.py

# Allow common ML/AI model files
!*.h5
!*.keras
!*.pt
!*.pth
!*.onnx
!*.pkl
!*.joblib
!*.tflite
!*.pb
!*.weights
!*.bin
!*.ckpt
!*.index
!*.meta

# Allow this .gitignore file itself to be tracked
!.gitignore
